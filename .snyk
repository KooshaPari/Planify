# Snyk policy — documents accepted risk / test-only findings
version: v1.25.0
ignore:
  python/NoHardcodedPasswords/test:
    - '*':
        reason: Test fixtures use synthetic credentials only; not production secrets.
        expires: '2027-06-01T00:00:00.000Z'
  python/NoHardcodedPasswords:
    - 'apps/api/plane/tests/**':
        reason: Test fixtures use synthetic credentials only; not production secrets.
        expires: '2027-06-01T00:00:00.000Z'
  python/NoHardcodedCredentials/test:
    - '*':
        reason: Contract tests use synthetic usernames; not production credentials.
        expires: '2027-06-01T00:00:00.000Z'
  python/NoHardcodedCredentials:
    - 'apps/api/plane/tests/**':
        reason: Contract tests use synthetic usernames; not production credentials.
        expires: '2027-06-01T00:00:00.000Z'
  python/HardcodedNonCryptoSecret/test:
    - '*':
        reason: Test fixtures use synthetic secrets only; not production values.
        expires: '2027-06-01T00:00:00.000Z'
  python/OR:
    - 'apps/api/plane/settings/storage.py':
        reason: Presigned S3 URLs are generated from admin-configured storage env vars and validated against an allowlist before redirect.
        expires: '2027-06-01T00:00:00.000Z'
  python/Server-SideRequestForgery:
    - 'apps/api/plane/authentication/adapter/oauth.py':
        reason: OAuth token and userinfo endpoints are fixed provider URLs from server configuration, not user-controlled targets.
        expires: '2027-06-01T00:00:00.000Z'
    - 'apps/api/plane/authentication/provider/oauth/github.py':
        reason: GitHub OAuth API calls target github.com endpoints configured by the provider adapter.
        expires: '2027-06-01T00:00:00.000Z'
    - 'apps/api/plane/authentication/provider/oauth/gitea.py':
        reason: Gitea OAuth API calls target the configured Gitea host from instance settings.
        expires: '2027-06-01T00:00:00.000Z'
    - 'apps/api/plane/authentication/authkit.py':
        reason: AuthKit callback uses AUTHKIT_API_URL from trusted deployment configuration validated at startup.
        expires: '2027-06-01T00:00:00.000Z'
    - 'apps/api/plane/bgtasks/copy_s3_object.py':
        reason: Internal live-service callback uses LIVE_URL from trusted deployment configuration.
        expires: '2027-06-01T00:00:00.000Z'
    - 'apps/api/plane/app/views/external/base.py':
        reason: Unsplash proxy pins host to api.unsplash.com; user input is query-encoded only.
        expires: '2027-06-01T00:00:00.000Z'
